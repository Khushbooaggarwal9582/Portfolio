/* Navbar */
nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 50px;
  background: rgba(0, 0, 0, 0.45);
  backdrop-filter: blur(5px);
  position: fixed;
  width: 100%;
  top: 0;
